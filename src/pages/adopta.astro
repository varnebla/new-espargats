---
import Layout from '@layouts/Layout.astro';
import {
  ShieldCheck,
  Syringe,
  Bug,
  TestTube,
  BookOpen,
  UserCheck,
  ArrowRight,
} from '@lucide/astro';
import Gallery from '@components/Gallery.astro';
import CallToAction from '@components/CallToAction.astro';
import SectionDivider from '@components/SectionDivider.astro';

const images = [
  { src: '/images/batman.webp', alt: 'Batman' },
  { src: '/images/elsa.avif', alt: 'Elsa' },
  { src: '/images/gato-desconocido.avif', alt: 'Gato desconocido' },
  { src: '/images/lola.avif', alt: 'Lola' },
  { src: '/images/mika.avif', alt: 'Mika' },
  { src: '/images/phil-leo.avif', alt: 'Phil y Leo' },
  { src: '/images/snow-teodoro.avif', alt: 'Snow y Teodoro' },
];

const guarantees = [
  {
    icon: ShieldCheck,
    title: 'Microchip y registro',
    text: 'Todos nuestros gatos se entregan identificados con microchip. Por defecto realizamos el registro en ANICOM, aunque también puedes solicitar registrarlo en AIAC con un coste adicional.',
    bg: 'bg-pastel-mint',
  },
  {
    icon: Syringe,
    title: 'Vacunación trivalente',
    text: 'Incluye la vacuna contra panleucopenia, calicivirus y rinotraqueítis felina. Si el gato está bajo tratamiento veterinario, la vacunación se pospone hasta que el veterinario lo autorice.',
    bg: 'bg-pastel-lavender',
  },
  {
    icon: Bug,
    title: 'Desparasitación completa',
    text: 'Aplicamos desparasitación interna y externa antes de la adopción, con una segunda dosis a los 14 días. Además, te facilitamos pautas para continuar con el protocolo según indicaciones veterinarias.',
    bg: 'bg-pastel-peach',
  },
  {
    icon: TestTube,
    title: 'Test FIV y FELV',
    text: 'A los gatos mayores de 6 meses se les realiza el test antes de la adopción. En los menores, se programa con la esterilización. Este punto es esencial para conocer su estado inmunológico.',
    bg: 'bg-pastel-yellow',
  },
  {
    icon: BookOpen,
    title: 'Cartilla veterinaria',
    text: 'Incluye todas las anotaciones de vacunación, desparasitación, estado de salud y pruebas realizadas. Te la entregamos al día, firmada y sellada por el veterinario.',
    bg: 'bg-pastel-mint',
  },
  {
    icon: UserCheck,
    title: 'Seguimiento personalizado',
    text: 'Después de la adopción, seguimos en contacto para ayudarte con dudas, consejos o acompañamiento durante el proceso de adaptación.',
    bg: 'bg-pastel-rose',
  },
];
---

<Layout
  title="Proceso de adopción"
  description="Adopta un gato con Espargats: conoce el proceso de adopción, requisitos, garantías veterinarias y beneficios de dar una segunda oportunidad a un felino rescatado en Barcelona."
>
  <!-- ── HERO ────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden pt-36 pb-16">
    <div
      class="absolute inset-0 bg-gradient-to-br from-pastel-mint/60 via-warm-cream to-pastel-peach/40 -z-10"
    >
    </div>
    <span
      class="absolute top-0 right-0 w-[520px] h-[520px] rounded-full bg-pastel-mint/50 blur-3xl -translate-y-1/2 translate-x-1/4 pointer-events-none"
      aria-hidden="true"></span>
    <span
      class="absolute bottom-0 left-0 w-96 h-96 rounded-full bg-pastel-yellow/40 blur-3xl translate-y-1/2 -translate-x-1/4 pointer-events-none"
      aria-hidden="true"></span>

    <!-- Copy centrado -->
    <div class="max-w-3xl mx-auto px-6 text-center mb-14">
      <span
        class="inline-flex items-center gap-2 text-primary/60 text-sm font-semibold tracking-widest uppercase mb-8 animate-fade-in animate-delay-100"
      >
        <span class="w-6 h-px bg-primary/30"></span>
        Adopción responsable · Esparreguera, Barcelona
        <span class="w-6 h-px bg-primary/30"></span>
      </span>
      <h1
        class="text-5xl md:text-6xl xl:text-7xl font-black text-primary tracking-tight leading-[1.05] mb-6 animate-fade-in-up animate-delay-200"
      >
        Adoptar
        <span class="relative inline-block">
          <span
            class="absolute inset-0 -skew-x-3 -skew-y-1 rounded-sm bg-pastel-yellow -z-10 scale-x-105 -translate-y-0.5"
            aria-hidden="true"></span>
          salva vidas.
        </span>
      </h1>
      <p
        class="text-base-content/65 text-xl leading-relaxed max-w-xl mx-auto mb-10 animate-fade-in animate-delay-300"
      >
        Cuando adoptas un gato de Espargats no solo le das un hogar: permites
        que otro pueda ocupar su lugar en la casa de acogida. Una adopción, dos
        vidas salvadas.
      </p>
    </div>

    <!-- Mosaico de gatos -->
    <div
      class="max-w-5xl mx-auto px-6 animate-blurred-fade-in animate-delay-500"
    >
      <!-- Mobile: columna solapada · Desktop: grid 3 columnas -->
      <div
        class="flex flex-col items-center md:grid md:grid-cols-3 md:gap-3 md:h-72"
      >
        <div
          class="rounded-3xl overflow-hidden shadow-lg border-4 border-white/80 -rotate-2 w-full max-w-sm h-48 md:w-auto md:h-full relative z-10 -mb-1 md:mb-0"
        >
          <img
            src="/images/mika.avif"
            alt="Mika"
            class="w-full h-full object-cover"
            fetchpriority="high"
            loading="eager"
          />
        </div>
        <div
          class="rounded-3xl overflow-hidden shadow-xl border-4 border-white/80 rotate-1 w-full max-w-sm h-48 md:w-auto md:h-full md:-mt-4 relative z-20 -mb-2 md:mb-0"
        >
          <img
            src="/images/espargats-hero-02.avif"
            alt="Gato rescatado"
            class="w-full h-full object-cover"
            fetchpriority="high"
            loading="eager"
          />
        </div>
        <div
          class="rounded-3xl overflow-hidden shadow-lg border-4 border-white/80 -rotate-3 md:rotate-2 w-full max-w-sm h-48 md:w-auto md:h-full md:mt-4 relative z-10"
        >
          <img
            src="/images/lola.avif"
            alt="Lola"
            class="w-full h-full object-cover"
            fetchpriority="high"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ── CÓMO ADOPTAR ───────────────────────────────────────── -->
  <section class="py-20 bg-base-200/60 relative overflow-clip">
    <span
      class="absolute top-0 right-0 w-72 h-72 rounded-full bg-pastel-peach/40 blur-3xl pointer-events-none"
      aria-hidden="true"></span>

    <div
      class="max-w-5xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center"
    >
      <div
        class="animate-fade-in-right animate-play-paused relative flex items-center justify-center order-2 lg:order-1"
      >
        <span
          class="absolute inset-0 rounded-3xl bg-pastel-mint/60 translate-x-3 translate-y-3 -z-10"
        ></span>
        <img
          src="/images/espargats-hero-03.avif"
          alt="¿Queréis adoptar?"
          class="rounded-3xl shadow-lg w-full object-cover border-4 border-white aspect-[4/3]"
          loading="lazy"
        />
      </div>

      <div
        class="animate-fade-in-left animate-play-paused flex flex-col justify-center order-1 lg:order-2"
      >
        <span
          class="inline-flex items-center gap-3 text-primary/60 text-sm font-semibold tracking-widest uppercase mb-5"
        >
          <span class="w-6 h-px bg-primary/30"></span>
          ¿Queréis adoptar?
        </span>
        <h2
          class="text-3xl md:text-4xl font-black text-primary tracking-tight leading-tight mb-6"
        >
          Así funciona el proceso
        </h2>
        <div class="space-y-4 text-base-content/75 text-lg leading-relaxed">
          <p>
            El primer paso es sencillo: cuéntanos qué gato te interesa por <a
              href="https://wa.me/34625017077"
              target="_blank"
              rel="noopener"
              class="text-primary font-semibold underline underline-offset-2"
              >WhatsApp</a
            > o rellenando nuestro <a
              href="https://www.espargats.com/formulario-adopcion"
              target="_blank"
              rel="noopener"
              class="text-primary font-semibold underline underline-offset-2"
              >formulario de adopción</a
            >.
          </p>
          <p>
            Respondemos siempre por WhatsApp, aunque puede que tardemos algunas
            horas: todo el equipo es voluntario. Te enviaremos fotos, vídeos y
            detalles sobre su carácter, salud y rutina.
          </p>
          <p>
            Si todo encaja, coordinamos una visita en nuestro veterinario
            colaborador para formalizar la adopción y firmar el contrato.
          </p>
        </div>
        <a
          href="https://www.espargats.com/formulario-adopcion"
          target="_blank"
          rel="noopener"
          class="btn btn-primary btn-md rounded-full w-fit font-bold px-7 mt-8 mx-auto lg:mx-0"
        >
          Inicia el proceso de adopción
        </a>
      </div>
    </div>
  </section>

  <SectionDivider from="hsl(38,50%,93%)" to="hsl(40,60%,97%)" />

  <!-- ── QUÉ INCLUYE ─────────────────────────────────────────── -->
  <section class="py-20 bg-warm-cream relative overflow-clip">
    <span
      class="absolute bottom-0 right-0 w-80 h-80 rounded-full bg-pastel-yellow/30 blur-3xl pointer-events-none"
      aria-hidden="true"></span>

    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14 animate-fade-in-up animate-play-paused">
        <span class="text-3xl mb-3 block" aria-hidden="true">✅</span>
        <h2
          class="text-3xl md:text-4xl font-black text-primary tracking-tight mb-4"
        >
          ¿Qué incluye la adopción?
        </h2>
        <p
          class="text-base-content/70 max-w-2xl mx-auto text-lg leading-relaxed"
        >
          Adoptar con Espargats significa hacerlo con la tranquilidad de que
          todo está en regla para el bienestar del gato y el tuyo.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {
          guarantees.map((g) => (
            <div
              class:list={[
                'rounded-3xl p-7 flex flex-col border border-white/70 shadow-sm animate-fade-in-up animate-play-paused',
                g.bg,
              ]}
            >
              <span class="mb-5 flex items-center justify-center w-12 h-12 rounded-2xl bg-white/60 shadow-sm">
                <g.icon size="24" stroke-width="1.8" class="text-primary" />
              </span>
              <h3 class="text-lg font-extrabold mb-3 text-primary">
                {g.title}
              </h3>
              <p class="text-base-content/75 text-base leading-relaxed">
                {g.text}
              </p>
            </div>
          ))
        }
      </div>

      <div
        class="flex justify-center mt-12 animate-fade-in-up animate-play-paused"
      >
        <a
          href="https://www.espargats.com/formulario-adopcion"
          target="_blank"
          rel="noopener"
          class="btn btn-primary btn-lg rounded-full px-10 py-2 font-bold shadow-md flex-wrap max-w-full h-auto"
        >
          Rellena el formulario y da el primer paso
        </a>
      </div>
    </div>
  </section>

  <SectionDivider from="hsl(40,60%,97%)" to="hsl(275,55%,95%)" />

  <!-- ── COMPROMISO + ADAPTACIÓN ────────────────────────────── -->
  <section
    class="py-20 relative overflow-clip"
    style="background: hsl(275,55%,95%)"
  >
    <span
      class="absolute top-0 left-0 w-72 h-72 rounded-full bg-pastel-lavender/40 blur-3xl pointer-events-none"
      aria-hidden="true"></span>
    <span
      class="absolute bottom-0 right-0 w-60 h-60 rounded-full bg-pastel-mint/30 blur-2xl pointer-events-none"
      aria-hidden="true"></span>

    <div class="max-w-5xl mx-auto px-6 space-y-24">
      <!-- Compromiso -->
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center"
      >
        <div
          class="animate-fade-in-left animate-play-paused flex flex-col justify-center"
        >
          <span
            class="inline-flex items-center gap-3 text-primary/60 text-sm font-semibold tracking-widest uppercase mb-5"
          >
            <span class="w-6 h-px bg-primary/30"></span>
            Tu compromiso
          </span>
          <h2
            class="text-3xl md:text-4xl font-black text-primary tracking-tight leading-tight mb-6"
          >
            Adoptar es para siempre
          </h2>
          <div class="space-y-4 text-base-content/75 text-lg leading-relaxed">
            <p>
              Adoptar significa hacerse responsable de un ser vivo para siempre.
              Es importante que tengas claro que quieres adoptar e incorporar un
              nuevo miembro a la familia.
            </p>
            <p>
              Si adoptas un gato menor de seis meses, deberás comprometerte a
              esterilizarlo a los seis meses en nuestro veterinario colaborador
              y enviarnos el comprobante.
            </p>
          </div>
          <a
            href="https://www.espargats.com/formulario-adopcion"
            target="_blank"
            rel="noopener"
            class="btn btn-primary btn-md rounded-full w-fit font-bold px-7 mt-8 mx-auto lg:mx-0"
          >
            Acepto el compromiso, quiero adoptar
          </a>
        </div>
        <div
          class="animate-fade-in-right animate-play-paused relative flex items-center justify-center"
        >
          <span
            class="absolute inset-0 rounded-3xl bg-pastel-yellow/50 translate-x-3 translate-y-3 -z-10"
          ></span>
          <img
            src="/images/about-01.webp"
            alt="Compromiso adoptante"
            class="rounded-3xl shadow-lg w-full object-cover border-4 border-white aspect-[4/3]"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Adaptación -->
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center"
      >
        <div
          class="animate-fade-in-left animate-play-paused relative flex items-center justify-center order-2 lg:order-1"
        >
          <span
            class="absolute inset-0 rounded-3xl bg-pastel-peach/50 -translate-x-3 translate-y-3 -z-10"
          ></span>
          <img
            src="/images/about-02.webp"
            alt="Adaptación gato hogar"
            class="rounded-3xl shadow-lg w-full object-cover border-4 border-white aspect-[4/3]"
            loading="lazy"
          />
        </div>
        <div
          class="animate-fade-in-right animate-play-paused flex flex-col justify-center order-1 lg:order-2"
        >
          <span
            class="inline-flex items-center gap-3 text-primary/60 text-sm font-semibold tracking-widest uppercase mb-5"
          >
            <span class="w-6 h-px bg-primary/30"></span>
            La adaptación
          </span>
          <h2
            class="text-3xl md:text-4xl font-black text-primary tracking-tight leading-tight mb-6"
          >
            Su nuevo hogar
          </h2>
          <div class="space-y-4 text-base-content/75 text-lg leading-relaxed">
            <p>
              Una buena adaptación es clave para su bienestar. Si lo necesitas,
              te enviaremos un pequeño dosier con consejos prácticos,
              especialmente útil si ya tienes otros animales en casa.
            </p>
            <p>
              En casos más complejos, podemos recomendarte un profesional
              especializado en comportamiento felino que te acompañe en el
              proceso.
            </p>
          </div>
          <a
            href="https://wa.me/34625017077"
            target="_blank"
            rel="noopener"
            class="btn btn-primary btn-md rounded-full w-fit font-bold px-7 mt-8 mx-auto lg:mx-0"
          >
            Quiero el dosier de adaptación
          </a>
        </div>
      </div>

      <!-- Por qué -->
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center"
      >
        <div
          class="animate-fade-in-left animate-play-paused flex flex-col justify-center"
        >
          <span
            class="inline-flex items-center gap-3 text-primary/60 text-sm font-semibold tracking-widest uppercase mb-5"
          >
            <span class="w-6 h-px bg-primary/30"></span>
            ¿Por qué Espargats?
          </span>
          <h2
            class="text-3xl md:text-4xl font-black text-primary tracking-tight leading-tight mb-6"
          >
            Cariño y responsabilidad
          </h2>
          <p class="text-base-content/75 text-lg leading-relaxed mb-8">
            Porque cada uno de nuestros gatos ha sido rescatado de la calle y
            merece una segunda oportunidad. Trabajamos desde el cariño y la
            responsabilidad. Cuando dos gatos tienen un vínculo afectivo fuerte,
            priorizamos su adopción conjunta. Y cada donación se destina al 100
            % al bienestar de nuestros felinos.
          </p>
          <a
            href="/about"
            class="btn btn-primary btn-md rounded-full w-fit font-bold px-7 mx-auto lg:mx-0"
          >
            Conoce más sobre Espargats
          </a>
        </div>
        <div
          class="animate-fade-in-right animate-play-paused relative flex items-center justify-center"
        >
          <span
            class="absolute inset-0 rounded-3xl bg-pastel-lavender/60 translate-x-3 -translate-y-3 -z-10"
          ></span>
          <img
            src="/images/about-03.webp"
            alt="Por qué adoptar con Espargats"
            class="rounded-3xl shadow-lg w-full object-cover border-4 border-white aspect-[4/3]"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <SectionDivider from="hsl(275,55%,95%)" to="hsl(38,50%,93%)" />

  <!-- ── GALERÍA ──────────────────────────────────────────────── -->
  <section class="py-20 bg-base-200/60">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14 animate-fade-in-up animate-play-paused">
        <span class="text-3xl mb-3 block" aria-hidden="true">🐱</span>
        <h2
          class="text-3xl md:text-4xl font-black text-primary tracking-tight mb-4"
        >
          Algunos de nuestros gatos adoptados
        </h2>
        <p
          class="text-base-content/70 max-w-xl mx-auto text-lg leading-relaxed"
        >
          Cada adopción es una historia de amor y esperanza. Aquí tienes una
          pequeña muestra.
        </p>
      </div>
      <Gallery images={images} />
    </div>
  </section>

  <!-- ── CTA FINAL ───────────────────────────────────────────── -->
  <CallToAction>
    <h2 slot="heading" class="text-2xl font-bold mb-8 text-primary text-center">
      ¿Lista para dar el paso?
    </h2>
    <p
      slot="description"
      class="text-base-content/60 text-center mb-8 max-w-2xl mx-auto"
    >
      Hay muchos gatos esperando un hogar. Si has llegado hasta aquí, quizá uno
      de ellos esté esperándote.
    </p>
    <div slot="actions" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <a
        href="https://www.espargats.com/formulario-adopcion"
        target="_blank"
        rel="noopener"
        class="btn btn-secondary btn-lg rounded-full flex items-center gap-2 justify-center"
      >
        <span>Adoptar un gato</span>
      </a>
      <a
        href="https://wa.me/34625017077"
        target="_blank"
        rel="noopener"
        class="btn btn-outline btn-lg rounded-full flex items-center gap-2 justify-center"
      >
        <span>Contactar por WhatsApp</span>
      </a>
    </div>
  </CallToAction>
</Layout>
