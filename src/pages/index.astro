---
import About from '@/components/About.astro';
import Adoption from '@/components/Adoption.astro';
import CallToAction from '@/components/CallToAction.astro';
import Contact from '@/components/Contact.astro';
import HelpUs from '@/components/HelpUs.astro';
import Hero from '@/components/Hero.astro';
import Mission from '@/components/Mission.astro';
import SectionDivider from '@/components/SectionDivider.astro';
import Testimonials from '@/components/Testimonials.astro';
import Layout from '@layouts/Layout.astro';

const title = 'Conoce a nuestros gatos en adopción';
const description =
  'Espargats es una asociación sin ánimo de lucro dedicada a rescatar y cuidar gatos callejeros en Esparreguera. Aquí puedes conocer a nuestros gatos en adopción y cómo puedes ayudarles.';
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'Espargats',
        url: 'https://www.espargats.com',
        logo: {
          '@type': 'ImageObject',
          url: 'https://www.espargats.com/favicon.svg',
        },
        description:
          'Asociación sin ánimo de lucro dedicada a rescatar y cuidar gatos callejeros en Esparreguera (Barcelona). Gestionamos colonias felinas mediante el método CES, fomentamos la adopción responsable y ayudamos a los gatos a encontrar hogar.',
        email: 'espargats@gmail.com',
        telephone: '+34625017077',
        address: {
          '@type': 'PostalAddress',
          addressLocality: 'Esparreguera',
          addressRegion: 'Barcelona',
          addressCountry: 'ES',
        },
        sameAs: [
          'https://www.instagram.com/espargats',
          'https://www.facebook.com/espargats',
          'https://www.tiktok.com/@espargats.com',
        ],
      })}
    />
  </Fragment>
  <Hero />
  <About />
  <SectionDivider from="hsl(40,60%,97%)" to="hsl(38,50%,93%)" />
  <Mission />
  <SectionDivider from="hsl(38,50%,93%)" to="hsl(40,60%,97%)" flip />
  <Adoption />
  <SectionDivider from="hsl(275,55%,95%)" to="hsl(38,50%,93%)" />
  <HelpUs />
  <Testimonials />
  <SectionDivider from="hsl(38,50%,93%)" to="hsl(275,42%,30%)" />
  <CallToAction />
  <!-- <Contact /> -->
</Layout>
