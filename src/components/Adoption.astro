---
import { Heart } from '@lucide/astro';
import SectionDivider from '@components/SectionDivider.astro';
const cats = [
  {
    name: 'Dulce',
    age: '1 año',
    gender: 'Macho',
    image: '/images/mika.avif',
    description: 'Un chico tranquilo y observador que adora los mimos al caer la tarde.',
    tags: ['Tranquilo', 'Mimoso', 'Curioso'],
  },
  {
    name: 'Cactus',
    age: '1 año',
    gender: 'Macho',
    image: '/images/phil-leo.avif',
    description: 'Juguetón y valiente, le encanta explorar cada rincón que encuentra.',
    tags: ['Juguetón', 'Valiente', 'Explorador'],
  },
  {
    name: 'Coco',
    age: '2 años',
    gender: 'Hembra',
    image: '/images/elsa.avif',
    description: 'Dulce y sociable, se lleva genial con otros gatos y con niños.',
    tags: ['Dulce', 'Sociable', 'Familiar'],
  },
];
---

<section class="py-20 bg-warm-cream relative overflow-hidden">
  <span class="absolute top-0 right-0 w-72 h-72 rounded-full bg-pastel-yellow/30 blur-3xl pointer-events-none" aria-hidden="true"></span>

  <div class="max-w-6xl mx-auto px-4 relative z-10">
    <!-- Encabezado -->
    <div class="text-center mb-12 animate-fade-in-up animate-play-paused">
      <span class="text-3xl mb-3 block" aria-hidden="true">😻</span>
      <h2 class="text-3xl md:text-4xl font-black text-center mb-4 text-primary tracking-tight">
        Encuentra tu compañero perfecto
      </h2>
      <p class="text-center text-base-content/70 max-w-2xl mx-auto text-lg leading-relaxed">
        Estos hermosos gatitos están esperando una familia que les dé amor y un hogar.
        ¿Podrías ser tú?
      </p>
    </div>

    <!-- Cards de gatos -->
    <div class="flex gap-5 overflow-x-auto overflow-y-visible snap-x snap-mandatory pb-4 mb-10 lg:grid lg:grid-cols-3 lg:overflow-visible lg:snap-none px-2 lg:px-0">
      {cats.map((cat) => (
        <article class="card bg-white shadow-md border border-base-200/80 flex flex-col min-w-[78vw] sm:min-w-[340px] max-w-xs snap-center lg:min-w-0 lg:w-full lg:max-w-none rounded-3xl overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-200 animate-fade-in-up animate-play-paused">
          <div class="relative w-full">
            <img
              src={cat.image}
              alt={`Foto de ${cat.name}`}
              class="w-full h-56 object-cover"
              loading="lazy"
            />
            <!-- Overlay gradiente suave -->
            <span class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent pointer-events-none"></span>
            <span class="absolute top-3 right-3 badge bg-pastel-yellow text-primary border-0 font-bold text-sm shadow-sm">
              {cat.age}
            </span>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <div class="flex justify-between items-center mb-2">
              <h4 class="text-xl font-extrabold text-primary">{cat.name}</h4>
              <span class="badge badge-ghost text-base-content/60 text-xs">{cat.gender}</span>
            </div>
            <p class="text-base-content/70 text-base mb-4 leading-relaxed flex-1">{cat.description}</p>
            <div class="flex flex-wrap gap-2 mb-5">
              {cat.tags.map((tag) => (
                <span class="badge bg-pastel-lavender text-primary border-0 text-xs font-semibold">{tag}</span>
              ))}
            </div>
            <a href="/adopta" class="btn btn-secondary btn-md rounded-full w-full font-bold flex items-center gap-2">
              <Heart size="17" />
              Adoptar a {cat.name}
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA ver todos -->
    <div class="flex justify-center">
      <a href="/adopta" class="btn btn-primary btn-lg rounded-full px-10 font-bold shadow-md">
        Conoce a todos nuestros gatos 🐱
      </a>
    </div>
  </div>
</section>

<SectionDivider from="hsl(40,60%,97%)" to="hsl(275,55%,95%)" />

<!-- Proceso de adopción -->
<section class="py-20" style="background: hsl(275,55%,95%)">
  <div class="max-w-5xl mx-auto px-4">
    <h3 class="text-2xl md:text-3xl font-black text-center mb-12 text-primary tracking-tight">
      Proceso de adopción responsable
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        { step: '1', title: 'Enamórate', text: 'Descubre a uno de nuestros gatitos y rellena el formulario de solicitud para que podamos conocerte mejor.' },
        { step: '2', title: 'Revisión', text: 'Revisaremos tu solicitud y te contactaremos para hacerte una pequeña entrevista y resolver tus dudas.' },
        { step: '3', title: '¡A casa!', text: 'Si todo cuadra, podrás venir a recoger a tu nuevo amor felino. Un vínculo para toda la vida os espera.' },
      ].map((item) => (
        <div class="bg-white rounded-3xl flex flex-col items-center text-center px-7 py-9 shadow-sm border border-white animate-fade-in-up animate-play-paused">
          <span class="flex items-center justify-center w-12 h-12 mb-5 rounded-full bg-primary text-primary-content text-lg font-black shadow-md">
            {item.step}
          </span>
          <h4 class="font-extrabold mb-3 text-lg text-primary">{item.title}</h4>
          <p class="text-base-content/70 text-base leading-relaxed">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
