---
import { HeartHandshake, Home, HandCoins, Users } from '@lucide/astro';
const helpWays = [
  {
    title: 'Adopta',
    description: 'Dale un hogar permanente a uno de nuestros gatos rescatados.',
    icon: Home,
    bg: 'bg-pastel-mint',
    iconBg: 'bg-emerald-200/60',
    emoji: '🏡',
    href: '/adopta',
  },
  {
    title: 'Dona',
    description: 'Contribuye con gastos veterinarios, alimentación y cuidados.',
    icon: HandCoins,
    bg: 'bg-pastel-yellow',
    iconBg: 'bg-amber-200/60',
    emoji: '💛',
    href: '/colabora',
  },
  {
    title: 'Voluntariado',
    description: 'Únete a nuestro equipo y ayúdanos en nuestro día a día.',
    icon: Users,
    bg: 'bg-pastel-lavender',
    iconBg: 'bg-purple-200/60',
    emoji: '🤝',
    href: '/colabora',
  },
  {
    title: 'Acogida',
    description:
      'Ofrece un hogar temporal mientras encuentran familia definitiva.',
    icon: HeartHandshake,
    bg: 'bg-pastel-rose',
    iconBg: 'bg-pink-200/60',
    emoji: '💗',
    href: '/colabora',
  },
];
---

<section class="py-20 bg-base-200/50 relative overflow-hidden">
  <span
    class="absolute bottom-0 left-0 w-64 h-64 rounded-full bg-pastel-mint/40 blur-3xl pointer-events-none"
    aria-hidden="true"></span>
  <span
    class="absolute top-0 right-0 w-48 h-48 rounded-full bg-pastel-rose/30 blur-2xl pointer-events-none"
    aria-hidden="true"></span>

  <div class="max-w-6xl mx-auto px-4 relative z-10">
    <div class="flex flex-col mb-12 md:items-center text-center">
      <span class="text-3xl mb-3" aria-hidden="true">🐾</span>
      <h2
        class="text-3xl md:text-4xl font-black tracking-tight mb-4 text-primary"
      >
        Cómo puedes ayudar
      </h2>
      <p class="text-base-content/70 text-lg max-w-xl leading-relaxed">
        Hay muchas formas de colaborar con nosotros. Encuentra la que mejor se
        ajuste a ti.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {
        helpWays.map((way) => (
          <a
            href={way.href}
            class:list={[
              'group rounded-3xl p-7 flex flex-col items-start border border-white/70 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200 cursor-pointer',
              way.bg,
            ]}
          >
            <span
              class:list={[
                'mb-5 flex items-center justify-center w-14 h-14 rounded-2xl shadow-sm',
                way.iconBg,
              ]}
            >
              <way.icon size="30" stroke-width="1.8" class="text-primary" />
            </span>
            <h3 class="text-lg font-extrabold mb-2 text-primary">
              {way.title}
            </h3>
            <p class="text-base-content/70 text-base leading-relaxed flex-1">
              {way.description}
            </p>
            <span class="mt-4 text-primary font-bold text-sm group-hover:gap-2 flex items-center gap-1 transition-all">
              Saber más →
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
