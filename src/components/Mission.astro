---
import { PawPrint, HeartHandshake, Home } from '@lucide/astro';

const pillars = [
  {
    icon: PawPrint,
    title: 'Rescate',
    description:
      'Rescatamos gatos de la calle, abandonados o en situaciones de peligro, brindándoles un refugio seguro.',
    bg: 'bg-pastel-peach',
    iconBg: 'bg-rose-200/60',
    emoji: '🆘',
  },
  {
    icon: HeartHandshake,
    title: 'Cuidado',
    description:
      'Mantenemos las colonias de gatos de nuestra localidad y proporcionamos acogida a los que pueden encontrar un hogar.',
    bg: 'bg-pastel-lavender',
    iconBg: 'bg-purple-200/60',
    emoji: '💜',
  },
  {
    icon: Home,
    title: 'Adopción',
    description:
      'Encontramos familias responsables y amorosas que brinden un hogar permanente a nuestros gatos.',
    bg: 'bg-pastel-mint',
    iconBg: 'bg-emerald-200/60',
    emoji: '🏡',
  },
];
---

<section class="py-20 bg-base-200/60">
  <div class="max-w-4xl mx-auto px-4">
    <div class="text-center mb-12 animate-fade-in-up animate-play-paused">
      <h2
        class="text-3xl md:text-4xl font-black md:text-center mb-4 text-primary tracking-tight"
      >
        Nuestra misión
      </h2>
      <p class="text-base-content/70 max-w-2xl mx-auto text-lg leading-relaxed">
        Trabajamos para defender, proteger y ayudar a los gatos abandonados o
        maltratados, con el propósito de ofrecerles una vida digna y un hogar
        donde puedan ser felices.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        pillars.map((p) => (
          <article
            class:list={[
              'rounded-3xl p-8 flex flex-col items-center text-center shadow-sm border border-white/80 animate-fade-in-up animate-play-paused',
              p.bg,
            ]}
          >
            <span
              class:list={[
                'mb-5 flex items-center justify-center rounded-2xl w-16 h-16 shadow-sm',
                p.iconBg,
              ]}
            >
              <p.icon size="32" stroke-width="1.8" class="text-primary" />
            </span>
            <h3 class="text-xl font-extrabold mb-3 text-primary">{p.title}</h3>
            <p class="text-base-content/75 leading-relaxed text-base">
              {p.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
