---

---

<section
  class="relative bg-warm-cream overflow-hidden pt-32 pb-16 min-h-[90vh] flex items-center"
>
  <!-- Blobs decorativos de fondo -->
  <span
    class="absolute top-0 right-0 w-[580px] h-[580px] rounded-full bg-pastel-lavender/50 blur-3xl -translate-y-1/3 translate-x-1/3 pointer-events-none"
    aria-hidden="true"></span>
  <span
    class="absolute bottom-24 left-0 w-72 h-72 rounded-full bg-pastel-peach/50 blur-2xl -translate-x-1/3 pointer-events-none"
    aria-hidden="true"></span>

  <div
    class="max-w-7xl mx-auto px-6 w-full grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-12 lg:gap-20 items-center"
  >
    <!-- LEFT: Copy -->
    <div class="hero-left flex flex-col order-1">
      <!-- Eyebrow -->
      <span
        class="inline-flex items-center gap-3 text-primary/60 text-sm font-semibold tracking-widest uppercase mb-8 animate-fade-in animate-delay-100"
      >
        <span class="w-8 h-px bg-primary/30"></span>
        Asociación sin ánimo de lucro · Esparreguera, Barcelona
      </span>

      <!-- Heading -->
      <h1
        class="text-5xl md:text-6xl xl:text-7xl font-black text-primary tracking-tight leading-[1.05] mb-6 text-pretty animate-fade-in-up animate-delay-200"
      >
        Cada gato merece un
        <span class="relative inline-block text-primary">
          <span
            class="absolute inset-0 -skew-x-3 -skew-y-1 rounded-sm bg-pastel-yellow -z-10 scale-x-105 -translate-y-0.5"
            aria-hidden="true"></span>
          hogar.
        </span>
      </h1>

      <!-- Body -->
      <p
        class="text-base-content/65 text-lg leading-relaxed max-w-md mb-10 animate-fade-in animate-delay-300"
      >
        Rescatamos, cuidamos y buscamos familia para los gatos callejeros de
        nuestra ciudad. Cada historia merece un final feliz.
      </p>

      <!-- CTAs -->
      <div
        class="flex flex-col sm:flex-row gap-4 mb-12 animate-fade-in animate-delay-400"
      >
        <a
          href="/adopta"
          class="btn btn-primary btn-lg rounded-full px-9 font-bold shadow-md"
        >
          Adoptar un gato
        </a>
        <a
          href="/colabora"
          class="btn btn-outline btn-lg rounded-full px-9 font-semibold border-primary/30 text-primary hover:bg-primary hover:text-primary-content"
        >
          Colaborar
        </a>
      </div>

      <!-- Pilares -->
      <div
        class="flex flex-wrap items-center gap-3 border-t border-primary/10 pt-8 animate-fade-in animate-delay-500"
      >
        <span
          class="inline-flex items-center gap-2 bg-pastel-peach text-primary text-sm font-semibold px-4 py-2 rounded-full"
        >
          🐾 Rescate
        </span>
        <span
          class="inline-flex items-center gap-2 bg-pastel-lavender text-primary text-sm font-semibold px-4 py-2 rounded-full"
        >
          🏠 Acogida
        </span>
        <span
          class="inline-flex items-center gap-2 bg-pastel-mint text-primary text-sm font-semibold px-4 py-2 rounded-full"
        >
          🐱 Adopción
        </span>
      </div>
    </div>

    <!-- RIGHT: Collage de fotos -->
    <div
      class="hero-right relative order-2 flex justify-center lg:justify-end animate-blurred-fade-in animate-delay-300"
    >
      <!-- Blob de fondo pastel -->
      <span
        class="absolute inset-4 rounded-[48px] bg-pastel-lavender/40 rotate-2 scale-95 pointer-events-none"
        aria-hidden="true"></span>

      <div
        class="relative w-full max-w-sm lg:max-w-none h-[460px] lg:h-[540px]"
      >
        <!-- Foto 1: retrato grande, izquierda -->
        <div
          class="absolute left-0 top-4 w-[54%] h-[72%] -rotate-2 z-20 shadow-xl rounded-3xl overflow-hidden border-4 border-white"
        >
          <img
            src="/images/espargats-hero-02.avif"
            alt="Gato rescatado por Espargats"
            class="w-full h-full object-cover"
            fetchpriority="high"
            loading="eager"
            decoding="async"
          />
        </div>

        <!-- Foto 2: pequeña, esquina superior derecha -->
        <div
          class="absolute right-2 top-0 w-[40%] h-[40%] rotate-2 z-10 shadow-lg rounded-2xl overflow-hidden border-4 border-white"
        >
          <img
            src="/images/lola.avif"
            alt="Lola, gata en adopción"
            class="w-full h-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>

        <!-- Foto 3: mediana, parte inferior derecha -->
        <div
          class="absolute right-0 bottom-2 w-[47%] h-[52%] -rotate-1 z-30 shadow-xl rounded-3xl overflow-hidden border-4 border-white"
        >
          <img
            src="/images/elsa.avif"
            alt="Elsa, gata rescatada"
            class="w-full h-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>

        <!-- Foto 4: pequeña, superpuesta en el centro-bajo -->
        <div
          class="absolute left-[36%] bottom-0 w-[28%] h-[32%] rotate-3 z-40 shadow-lg rounded-2xl overflow-hidden border-4 border-white"
        >
          <img
            src="/images/snow-teodoro.avif"
            alt="Snow y Teodoro, gatos acogidos"
            class="w-full h-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(28px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .hero-left {
    animation: fade-up 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.05s both;
  }
  .hero-right {
    animation: fade-up 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.22s both;
  }
</style>
