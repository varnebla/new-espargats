---
import '@styles/global.css';
import { Font } from 'astro:assets';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es" data-theme="fantasy">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={Astro.url.href} />
    <Font cssVariable="--font-sora" preload />
    <Font cssVariable="--font-general-sans" />

    <title>{title} | Espargats en Barcelona</title>
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Espargats en Barcelona`} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content={new URL('/images/about-01.webp', Astro.site).href}
    />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="espargats.com" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta name="twitter:title" content={`${title} | Espargats en Barcelona`} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content={new URL('/images/about-01.webp', Astro.site).href}
    />
    <slot name="head" />
  </head>

  <body class="flex flex-col min-h-screen z-10">
    <Header />
    <main class="flex-1 z-0">
      <slot />
    </main>
    <Footer />
  </body><script>
    const observer = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.remove('animate-play-paused');
            obs.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.12 },
    );
    document
      .querySelectorAll('.animate-play-paused')
      .forEach((el) => observer.observe(el));
  </script><style>
    html,
    body {
      margin: 0;
      width: 100%;
      height: 100%;
    }
  </style>
</html>
